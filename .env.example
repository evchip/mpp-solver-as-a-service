# Tempo Mainnet
TEMPO_RPC_URL=https://rpc.tempo.xyz

# Your wallet address - receives USDC payments from MPP
SERVICE_WALLET_ADDRESS=0x...

# Kalshi API (ECDSA P-256 signed headers)
KALSHI_API_KEY=...
KALSHI_API_KEY_ID=...
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Polymarket CLOB (for solver order placement)
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Solver needs a Polymarket CLOB API key + funded Polygon wallet
SOLVER_POLYGON_PRIVATE_KEY=0x...

# Polygon RPC (for CTF token transfers)
POLYGON_RPC_URL=https://polygon-rpc.com
